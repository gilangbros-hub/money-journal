<!DOCTYPE html>
<html lang="en">

<head>
    {{> head}}
    <title>Check Pockets</title>
</head>

<body>
    <div class="page-container journal-shell">
        <!-- Header -->
        <header class="app-header">
            <div onclick="window.location.href='/monthly-story'" class="cursor-pointer">
                <p class="journal-eyebrow"><a href="/monthly-story" style="color: inherit; text-decoration: none;">← Back</a></p>
                <h1 class="page-title page-title-ledger">Check Pockets</h1>
            </div>
            <div class="user-info" onclick="toggleMenu()">
                <span class="text-sm font-semibold" style="color: var(--journal-soft-ink);">{{username}}</span>
                <span class="text-[28px]">{{avatar}}</span>
            </div>
            <div id="userMenu" class="user-menu" style="background: var(--journal-panel); border: 1px solid var(--journal-line);">
                <a href="/profile" style="color: var(--journal-ink);">Edit Profile</a>
                <a href="/logout" class="logout" style="color: var(--journal-danger);">Logout</a>
            </div>
        </header>

        <!-- Month Selector -->
        <div class="journal-hero-card flex items-center justify-center gap-4 mb-5 p-4 rounded-2xl">
            <button class="bg-white/10 border-none w-10 h-10 rounded-xl cursor-pointer flex items-center justify-center transition-colors duration-200 hover:bg-white/20 text-white" id="prevMonth">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <div class="text-lg font-bold text-white min-w-[160px] text-center" id="currentMonth">Februari 2026</div>
            <button class="bg-white/10 border-none w-10 h-10 rounded-xl cursor-pointer flex items-center justify-center transition-colors duration-200 hover:bg-white/20 text-white" id="nextMonth">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>

        <!-- Role Notice -->
        {{#unless canEdit}}
        <div class="bg-amber/20 text-amber p-3 px-4 rounded-xl text-sm mb-4 flex items-center gap-2 border border-amber/30">
            <span>👁️</span> View-only mode. Only Wife can edit budgets.
        </div>
        {{/unless}}

        <!-- Financial Health Summary — Pie Chart -->
        <div class="journal-hero-card" id="healthCard">
            <div class="relative w-full max-w-[220px] mx-auto mb-4">
                <canvas id="budgetPieChart"></canvas>
            </div>
            <div class="text-center mt-2">
                <span class="journal-total-label block m-0">Total Budget</span>
                <span class="journal-total-amount block" id="totalBudgetDisplay" style="font-size: 1.8rem; margin-bottom: 0;">Rp 0</span>
            </div>
            <div class="flex justify-between mt-5 px-2">
                <div class="flex flex-col items-center">
                    <span class="journal-metric-label mb-1" style="color: #b7bdd0;">Spent</span>
                    <span class="journal-metric-value" style="color: #fca5a5;" id="totalSpentDisplay">Rp 0</span>
                </div>
                <div class="flex flex-col items-center">
                    <span class="journal-metric-label mb-1" style="color: #b7bdd0;">Remaining</span>
                    <span class="journal-metric-value" style="color: #bef264;" id="totalRemainingDisplay">Rp 0</span>
                </div>
            </div>
        </div>

        <!-- Budget List -->
        <div class="section-header">
            <h2 class="section-title" style="color: var(--journal-ink);">Pocket Breakdown</h2>
        </div>
        <div class="journal-group-rows mb-4" id="budgetList">
            <p class="text-center py-5" style="color: var(--journal-soft-ink);">Loading budgets...</p>
        </div>

        <!-- History Button -->
        <button class="transaction-save-btn" style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 10px;" onclick="showHistory()">
            <span class="material-symbols-outlined">history</span>
            View History
        </button>
    </div>

    <!-- Edit Modal -->
    <div id="editModal" class="modal-overlay">
        <div class="modal-card">
            <h3>Edit Budget</h3>
            <div class="text-lg font-semibold mb-5 text-text-secondary" id="modalPocket">💰 Pocket Name</div>
            <div class="flex items-center bg-bg-tertiary rounded-2xl p-4 mb-6">
                <span class="text-xl font-bold text-text-primary mr-2">Rp</span>
                <input type="number" id="budgetInput" placeholder="0" min="0"
                    class="border-none bg-transparent text-2xl font-bold text-text-primary w-full outline-none">
            </div>
            <div class="modal-actions">
                <button class="btn-modal-cancel" onclick="closeModal()">Cancel</button>
                <button class="btn-modal-save" onclick="saveBudget()">Save</button>
            </div>
        </div>
    </div>

    <!-- History Modal -->
    <div id="historyModal" class="modal-overlay">
        <div class="modal-card max-h-[70vh] overflow-y-auto" style="max-width: 380px;">
            <h3>Budget History</h3>
            <div id="historyList" class="text-left">
                <p class="text-center text-text-muted py-5">Loading...</p>
            </div>
            <button class="btn-modal-cancel w-full mt-4" onclick="closeHistoryModal()">Close</button>
        </div>
    </div>

    <!-- Hidden Data -->
    <input type="hidden" id="canEdit" value="{{canEdit}}">
    <input type="hidden" id="userRole" value="{{role}}">

    <div id="message" class="toast"></div>

    {{> actionHub}}

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/common.js"></script>
    <script src="/js/check-pockets.js"></script>
</body>

</html>
