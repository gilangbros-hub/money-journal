<!DOCTYPE html>
<html lang="en">

<head>
    {{> head}}
    <title>Log Spending</title>
</head>

<body class="transaction-screen">
    <div class="page-container transaction-layout">
        <header class="app-header" style="justify-content: flex-start; gap: 1rem;">
            <a href="/monthly-story" class="btn-ghost" style="width: 40px; height: 40px; padding: 0; border-radius: 12px; display: flex; align-items: center; justify-content: center; text-decoration: none;">
                <span class="material-symbols-outlined" style="font-size: 20px;">arrow_back</span>
            </a>
            <div style="flex: 1;">
                <p class="journal-eyebrow">Money Journal</p>
                <h1 class="page-title page-title-ledger transaction-title">Log Spending <span class="inline-flex items-center gap-1 bg-gradient-danger text-white py-1 px-3 rounded-full text-xs font-bold ml-2 align-middle" id="streakBadge" style="display:none;"></span></h1>
            </div>
            <div class="user-info" onclick="toggleMenu()" style="margin-left: auto;">
                <span class="text-sm font-semibold text-text-secondary">{{username}}</span>
                <span class="text-[28px]">{{avatar}}</span>
            </div>
            <div id="userMenu" class="user-menu">
                <a href="/profile">Edit Profile</a>
                <a href="/logout" class="logout">Logout</a>
            </div>
        </header>

        <input type="hidden" id="currentUsername" value="{{username}}">

        <form id="transactionForm">
            <input type="hidden" id="transactionId" name="transactionId">

            <div class="transaction-shell">
                <section class="transaction-counter">
                    <p class="transaction-counter-label">Amount</p>
                    <p class="transaction-counter-currency">Rp</p>
                    <input type="number" id="amount" name="amount" placeholder="0" required class="transaction-counter-input">
                </section>

                <section class="transaction-section">
                    <label class="transaction-field-label" for="ngapain">Description</label>
                    <input type="text" id="ngapain" name="ngapain" placeholder="What did you spend on?" required class="transaction-note-input">
                </section>

                <section class="transaction-section transaction-rows">
                    <button type="button" class="transaction-row" id="categoryTrigger">
                        <span class="transaction-row-label">Category</span>
                        <span class="transaction-row-value" id="selectedTypeDisplay">Eat</span>
                    </button>

                    <div class="transaction-mode-toggle">
                        <label class="transaction-mode-pill">
                            <input type="radio" name="sourceType" value="single" checked id="sourceTypeSingle">
                            <span>Single Pocket</span>
                        </label>
                        <label class="transaction-mode-pill">
                            <input type="radio" name="sourceType" value="multi" id="sourceTypeMulti">
                            <span>Multi Pocket</span>
                        </label>
                    </div>

                    <button type="button" class="transaction-row" id="pocketTrigger">
                        <span class="transaction-row-label">Pocket</span>
                        <span class="transaction-row-value" id="selectedPocketDisplay">Kwintals</span>
                    </button>

                    <div class="transaction-breakdown-panel" id="multiPocketSection" style="display:none;">
                        <div class="transaction-breakdown-head">
                            <span>Pocket Breakdown</span>
                            <button type="button" class="transaction-breakdown-add" id="addPocketBtn" onclick="addBreakdownRow()">Add Pocket</button>
                        </div>
                        <div class="breakdown-container" id="breakdownRows"></div>
                        <div class="breakdown-total mt-4" id="breakdownTotalCard">
                            <div class="breakdown-total-row mb-2">
                                <span class="label">Allocated</span>
                                <span class="value" id="allocatedTotal">Rp 0</span>
                            </div>
                            <div class="breakdown-total-row mb-2">
                                <span class="label">Transaction Amount</span>
                                <span class="value" id="transactionAmountDisplay">Rp 0</span>
                            </div>
                            <div class="breakdown-total-row">
                                <span class="label">Difference</span>
                                <span class="value" id="differenceDisplay">Rp 0</span>
                            </div>
                            <div class="breakdown-progress">
                                <div class="breakdown-progress-fill" id="breakdownProgressFill" style="width: 0%"></div>
                            </div>
                        </div>
                    </div>

                    <div id="singlePocketSection" style="display:none;">
                        {{#each (split "Kwintals,Groceries,Weekday Transport,Weekend Transport,Investasi,Bandung,Sedeqah,IPL")}}
                        <input type="radio" name="pocket" value="{{this}}" class="option-input pocket-hidden-input" data-pocket-label="{{this}}">
                        {{/each}}
                    </div>

                    <label class="transaction-row relative" style="position: relative; cursor: pointer;">
                        <span class="transaction-row-label">Date & Time</span>
                        <span class="transaction-row-value" id="dateDisplay">25 Apr · 10:06 PM</span>
                        <input type="datetime-local" id="date" name="date" required style="position: absolute; opacity: 0; width: 100%; height: 100%; top: 0; left: 0; cursor: pointer;">
                    </label>

                    <div class="transaction-budget-month">
                        <p class="transaction-field-label">Budget Month</p>
                        <div class="transaction-budget-options" id="budgetMonthOptions"></div>
                        <select id="budgetMonth" name="budgetMonth" required class="sr-only"></select>
                    </div>
                </section>

                <button type="submit" class="transaction-save-btn" id="submitBtn">Save Transaction</button>
            </div>

            <div class="transaction-hidden-types" aria-hidden="true">
                {{#each (split "Eat,Snack,Groceries,Laundry,Bensin,Flazz,Home Appliance,Jumat Berkah,Uang Sampah,Uang Keamanan,Medicine,Others")}}
                <input type="radio" name="type" value="{{this}}" class="option-input type-hidden-input" data-type-label="{{this}}" required>
                {{/each}}
            </div>
        </form>
    </div>

    <div class="picker-sheet-overlay" id="typeSheet">
        <div class="picker-sheet-card">
            <div class="picker-sheet-head">
                <h3>Expense Type</h3>
                <button type="button" class="picker-sheet-close" data-close-sheet="typeSheet">Close</button>
            </div>
            <div class="picker-grid">
                {{#each (split "Eat,Snack,Groceries,Laundry,Bensin,Flazz,Home Appliance,Jumat Berkah,Uang Sampah,Uang Keamanan,Medicine,Others")}}
                <button type="button" class="picker-grid-item" data-type-option="{{this}}">
                    <span class="picker-grid-icon">{{getEmoji this}}</span>
                    <span>{{this}}</span>
                </button>
                {{/each}}
            </div>
        </div>
    </div>

    <div class="picker-sheet-overlay" id="pocketSheet">
        <div class="picker-sheet-card">
            <div class="picker-sheet-head">
                <h3>Pocket Source</h3>
                <button type="button" class="picker-sheet-close" data-close-sheet="pocketSheet">Close</button>
            </div>
            <div class="picker-grid">
                {{#each (split "Kwintals,Groceries,Weekday Transport,Weekend Transport,Investasi,Bandung,Sedeqah,IPL")}}
                <button type="button" class="picker-grid-item" data-pocket-option="{{this}}">
                    <span class="picker-grid-icon">{{getPocketEmoji this}}</span>
                    <span>{{this}}</span>
                </button>
                {{/each}}
            </div>
        </div>
    </div>

        <div id="successModal" class="modal-overlay">
        <div class="modal-card text-center">
            <div class="text-5xl mb-4" id="successEmoji">Saved</div>
            <h3 class="text-xl font-bold text-text-primary mb-2">Transaction Saved!</h3>
            <p class="text-sm text-text-secondary mb-6" id="successMessage">Great job tracking your expenses!</p>
            <div class="flex flex-col gap-3">
                <button class="btn-neon w-full h-12" onclick="addAnother()">Add Another</button>
                <button class="btn-ghost w-full h-12" onclick="window.location.href='/monthly-story'">Go to Monthly Story</button>
            </div>
        </div>
    </div>

    <div id="message" class="toast"></div>
    <script src="/js/common.js"></script>
    <script src="/js/confetti.js"></script>
    <script src="/js/log-spending.js"></script>
</body>

</html>
