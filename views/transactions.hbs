<!DOCTYPE html>
<html lang="en">

<head>
    {{> head}}
    <title>📊 Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
</head>

<body>
    <div class="page-container">
        <!-- Header -->
        <header class="app-header">
            <h1 class="page-title">📊 Dashboard</h1>
            <div class="user-info" onclick="toggleMenu()">
                <span class="text-sm font-semibold text-text-secondary">{{username}}</span>
                <span class="text-[28px]">{{avatar}}</span>
            </div>
            <div id="userMenu" class="user-menu">
                <a href="/profile">Edit Profile</a>
                <a href="/logout" class="logout">Logout</a>
            </div>
        </header>

        <!-- Summary Card -->
        <div class="hero-card">
            <input type="month" id="monthFilter" class="bg-white/20 border-none text-white py-1 px-3 rounded-full text-sm font-medium cursor-pointer backdrop-blur mb-4 inline-block focus:outline-none focus:bg-white/30" style="-webkit-appearance: none;">
            <div class="text-sm opacity-90 mb-1">Total Expenses</div>
            <h1 class="text-rupiah-lg m-0 tracking-tight" id="totalAmount">Rp 0</h1>
        </div>

        <!-- Monthly Comparison Card -->
        <div id="comparisonCard" class="bg-bg-secondary rounded-2xl p-4 flex items-center gap-3 mb-5 shadow-card border border-border/50" style="display: none;">
            <div class="text-[32px]" id="comparisonIcon">📊</div>
            <div class="flex flex-col">
                <span class="text-xs text-text-secondary mb-0.5">vs Last Month</span>
                <span class="text-base font-bold" id="comparisonValue">-</span>
            </div>
        </div>

        <!-- Spending Breakdown Pie Chart -->
        <div class="chart-card">
            <div class="section-header">
                <h2 class="section-title">Spending Breakdown</h2>
            </div>
            <div class="h-[200px] relative">
                <canvas id="spendingChart"></canvas>
            </div>
            <div id="chartLegend" class="grid grid-cols-2 gap-2 mt-4">
                <!-- Injected by JS -->
            </div>
        </div>

        <!-- Categories Section -->
        <div class="section-header">
            <h2 class="section-title">By Category</h2>
        </div>
        <div class="flex flex-col gap-4 mb-8" id="categoryList">
            <!-- Injected by JS -->
            <p class="text-center text-text-muted">Loading categories...</p>
        </div>

        <!-- Recent Transactions -->
        <div class="section-header">
            <h2 class="section-title" id="recentTransactionsHeader">Recent Transactions</h2>
            <div class="flex gap-4 items-center">
                <a href="/all-transactions" id="viewAllLink" class="text-sm font-semibold text-primary no-underline hover:text-primary-light transition-colors">View All</a>
                <button onclick="exportToCSV()" class="text-sm font-semibold text-lime bg-transparent border-none cursor-pointer hover:text-lime-light transition-colors">Export</button>
            </div>
        </div>

        <div class="flex flex-col gap-3" id="historyList">
            <!-- Injected by JS -->
        </div>

    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="modal-overlay">
        <div class="modal-card">
            <div class="text-5xl mb-4">🗑️</div>
            <h3>Delete this?</h3>
            <p id="deleteDetails" class="text-text-secondary mb-5"></p>
            <div class="modal-actions">
                <button class="btn-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
                <button class="btn-modal-danger" onclick="confirmDelete()">Delete</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="/js/common.js"></script>
    <script src="/js/transactions.js"></script>

    {{> navbar isDashboard=true}}
</body>

</html>