<!DOCTYPE html>
<html lang="en">

<head>
    {{> head}}
    <title>Journal</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
</head>

<body>
    <div class="page-container journal-shell">
        <header class="app-header">
            <div>
                <p class="journal-eyebrow">Money Journal</p>
                <h1 class="page-title page-title-ledger">Today</h1>
            </div>
            <div class="user-info" onclick="toggleMenu()">
                <span class="text-sm font-semibold text-text-secondary">{{username}}</span>
                <span class="text-[28px]">{{avatar}}</span>
            </div>
            <div id="userMenu" class="user-menu">
                <a href="/profile">Edit Profile</a>
                <a href="/logout" class="logout">Logout</a>
            </div>
        </header>

        <section class="journal-hero-card">
            <div class="journal-hero-row">
                <input type="month" id="monthFilter" class="journal-month-input">
                <button type="button" class="journal-chip-btn" id="jumpToTodayBtn">Jump to Today</button>
            </div>
            <p class="journal-total-label">This Month</p>
            <h2 class="journal-total-amount" id="totalAmount">Rp 0</h2>
            <div class="journal-hero-metrics">
                <div>
                    <p class="journal-metric-label">Today</p>
                    <p class="journal-metric-value" id="todayAmount">Rp 0</p>
                </div>
                <div>
                    <p class="journal-metric-label">Entries</p>
                    <p class="journal-metric-value" id="entryCount">0</p>
                </div>
                <div>
                    <p class="journal-metric-label">Nudge</p>
                    <p class="journal-metric-value" id="monthNudge">Steady</p>
                </div>
            </div>
        </section>

        <section class="journal-strip">
            <button class="journal-strip-item" onclick="location.href='/transaction'">
                <span class="material-symbols-outlined">edit_note</span>
                Log Spending
            </button>
            <button class="journal-strip-item" onclick="location.href='/all-transactions'">
                <span class="material-symbols-outlined">history</span>
                Review Feed
            </button>
            <button class="journal-strip-item" onclick="location.href='/budget'">
                <span class="material-symbols-outlined">account_balance_wallet</span>
                Check Pockets
            </button>
        </section>

        <section class="journal-story-grid" id="storyCards">
            <article class="journal-story-card">
                <p class="journal-story-kicker">Shift vs last month</p>
                <h3 class="journal-story-title" id="comparisonValue">Loading...</h3>
                <p class="journal-story-desc">Tracking movement keeps spending decisions calm.</p>
            </article>
            <article class="journal-story-card">
                <p class="journal-story-kicker">Top category</p>
                <h3 class="journal-story-title" id="topCategory">Loading...</h3>
                <p class="journal-story-desc" id="topCategoryAmount">Rp 0</p>
            </article>
        </section>

        <section class="journal-surface">
            <div class="section-header">
                <h2 class="section-title">Today Feed</h2>
                <a href="/all-transactions" class="journal-surface-link">View Full Feed</a>
            </div>
            <div class="journal-timeline" id="todayTimeline">
                <p class="text-center text-text-muted py-5">Loading today...</p>
            </div>
        </section>

        <section class="journal-surface">
            <div class="section-header">
                <h2 class="section-title">Pocket Pulse</h2>
            </div>
            <div id="pocketPulseList">
                <p class="text-center text-text-muted py-5">Reading pocket signals...</p>
            </div>
        </section>

        <section class="journal-surface">
            <div class="section-header">
                <h2 class="section-title">Spending Breakdown</h2>
            </div>
            <div class="h-[200px] relative">
                <canvas id="spendingChart"></canvas>
            </div>
            <div id="chartLegend" class="grid grid-cols-2 gap-2 mt-4">
            </div>
        </section>

        <section class="journal-surface">
            <div class="section-header">
                <h2 class="section-title">Month Feed</h2>
            </div>
            <div id="historyList">
                <p class="text-center text-text-muted py-5">Loading month feed...</p>
            </div>
        </section>
    </div>

    <div id="deleteModal" class="modal-overlay">
        <div class="modal-card">
            <div class="text-5xl mb-4">Delete</div>
            <h3>Delete this?</h3>
            <p id="deleteDetails" class="text-text-secondary mb-5"></p>
            <div class="modal-actions">
                <button class="btn-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
                <button class="btn-modal-danger" onclick="confirmDelete()">Delete</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="/js/common.js"></script>
    <script src="/js/transactions.js"></script>

    {{> actionHub}}
</body>

</html>
