<!DOCTYPE html>
<html lang="en">

<head>
    {{> head}}
    <title>Welcome - Money Journal</title>
</head>

<body class="flex justify-center items-center h-screen overflow-hidden flex-col" style="background: radial-gradient(circle at top right, #efe6d5 0%, transparent 46%), var(--journal-bg);">
    <div class="page-title-ledger opacity-0 translate-y-2.5 animate-fade-in text-center" style="font-size: 38px; color: var(--journal-ink); animation: fadeInUp 0.8s ease forwards;">
        Hi! {{username}} 👋
    </div>
    <div class="opacity-0 translate-y-2.5 mt-2 text-center" id="streakDisplay" style="font-size: 16px; font-weight: 800; color: var(--journal-soft-ink); animation: fadeInUp 0.8s 0.4s ease forwards;"></div>
    <div class="opacity-0 translate-y-2.5 mt-4 text-center journal-metric-label" id="motivationDisplay" style="animation: fadeInUp 0.8s 0.7s ease forwards;"></div>

    <style>
        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>

    <script>
        // Show streak info
        const streakData = JSON.parse(localStorage.getItem('moneyJournalStreak') || '{"count":0,"lastDate":""}');
        const today = new Date().toISOString().slice(0, 10);
        const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);

        let streakCount = 0;
        if (streakData.lastDate === today || streakData.lastDate === yesterday) {
            streakCount = streakData.count;
        }

        const streakEl = document.getElementById('streakDisplay');
        const motivationEl = document.getElementById('motivationDisplay');

        if (streakCount > 0) {
            streakEl.textContent = `🔥 ${streakCount}-day tracking streak`;

            const motivations = {
                low: ['Keep it going!', 'Building a habit 💪', 'Every day counts!'],
                mid: ['You\'re unstoppable!', 'Consistency is key 🔑', 'Financial ninja! 🥷'],
                high: ['Legendary discipline! 👑', 'Money master! 💎', 'Absolute beast mode! 🏆']
            };

            let pool = motivations.low;
            if (streakCount >= 14) pool = motivations.high;
            else if (streakCount >= 5) pool = motivations.mid;

            motivationEl.textContent = pool[Math.floor(Math.random() * pool.length)];
        } else {
            streakEl.textContent = 'Let\'s track your spending today!';
            motivationEl.textContent = 'Start your streak 🚀';
        }

        // Redirect after delay
        setTimeout(() => {
            window.location.href = '/monthly-story';
        }, 3000);
    </script>
</body>

</html>