<!DOCTYPE html>
<html lang="en">

<head>
    {{> head}}
    <title>Money Journal - Login</title>
</head>

<body class="flex flex-col items-center min-h-screen">

    <!-- Dark Header -->
    <div class="auth-header-bg">
        <img src="/images/logo.png" alt="Money Journal Logo" class="w-[72px] h-[72px] object-contain rounded-2xl mb-5">
        <h1 class="text-white text-[26px] font-bold mb-1.5">Welcome Back</h1>
        <p class="text-white/55 text-sm">Sign in to your account</p>
    </div>

    <!-- Form Card -->
    <div class="auth-card">
        <h2 class="text-[22px] font-bold text-text-primary mb-5">Sign In</h2>

        {{#if error}}
        <div class="bg-coral/20 text-coral-light p-2.5 px-3.5 rounded-[10px] text-[13px] mb-4 border border-coral/30">{{error}}</div>
        {{/if}}

        {{#if success}}
        <div class="bg-lime/20 text-lime-light p-2.5 px-3.5 rounded-[10px] text-[13px] mb-4 border border-lime/30">{{success}}</div>
        {{/if}}

        <form method="POST" action="/auth/login">
            <div class="field-group">
                <label for="username">Username</label>
                <div class="relative">
                    <input type="text" id="username" name="username" placeholder="your_username" required
                        autocomplete="username">
                </div>
            </div>

            <div class="field-group">
                <label for="password">Password</label>
                <div class="relative">
                    <input type="password" id="password" name="password" placeholder="••••••••" required
                        autocomplete="current-password">
                    <button type="button" class="absolute right-3.5 top-1/2 -translate-y-1/2 bg-transparent border-none cursor-pointer text-text-muted flex items-center" onclick="togglePw('password', this)"
                        aria-label="Toggle password">
                        <span class="material-symbols-outlined" style="font-size:20px;">visibility_off</span>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-neon mt-2 h-[52px]">Sign In</button>
        </form>

        <div class="text-center mt-5 text-sm text-text-secondary">
            I'm a new user. <a href="/register" class="text-primary font-bold no-underline hover:text-primary-light">Register</a>
        </div>
    </div>

    <script>
        function togglePw(id, btn) {
            const input = document.getElementById(id);
            const icon = btn.querySelector('span');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        }
    </script>
</body>

</html>