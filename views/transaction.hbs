<!DOCTYPE html>
<html lang="en">

<head>
    {{> head}}
    <title>Add Transaction</title>
</head>

<body>
    <div class="page-container">
        <!-- Header -->
        <header class="app-header">
            <h1 class="page-title">📝 Add Transaction <span class="inline-flex items-center gap-1 bg-gradient-danger text-white py-1 px-3 rounded-full text-xs font-bold ml-2 align-middle" id="streakBadge" style="display:none;"></span></h1>
            <div class="user-info" onclick="toggleMenu()">
                <span class="text-sm font-semibold text-text-secondary">{{username}}</span>
                <span class="text-[28px]">{{avatar}}</span>
            </div>
            <div id="userMenu" class="user-menu">
                <a href="/profile">Edit Profile</a>
                <a href="/logout" class="logout">Logout</a>
            </div>
        </header>

        <input type="hidden" id="currentUsername" value="{{username}}">
        <form id="transactionForm">
            <input type="hidden" id="transactionId" name="transactionId">

            <!-- 1. Expense Type -->
            <div class="mb-7">
                <div class="text-[13px] font-bold uppercase tracking-wider text-text-secondary mb-3 flex items-center gap-1.5"><span>🏷️</span> Expense Type</div>
                <div class="option-grid">
                    {{!-- prettier-ignore --}}
                    {{#each (split "Eat,Snack,Groceries,Laundry,Bensin,Flazz,Home Appliance,Jumat Berkah,Uang
                    Sampah,Uang Keamanan,Medicine,Others")}}
                    <label>
                        <input type="radio" name="type" value="{{this}}" class="option-input" required>
                        <div class="icon-btn">
                            <span class="text-[28px] mb-1.5">{{getEmoji this}}</span>
                            <span class="text-[11px] font-semibold text-center text-text-secondary">{{this}}</span>
                        </div>
                    </label>
                    {{/each}}
                </div>
            </div>

            <!-- 2. Notes -->
            <div class="mb-7">
                <div class="text-[13px] font-bold uppercase tracking-wider text-text-secondary mb-3 flex items-center gap-1.5"><span>📝</span> Description</div>
                <input type="text" id="ngapain" name="ngapain" placeholder="What did you buy?" required class="input-dark">
            </div>

            <!-- 3. Amount -->
            <div class="mb-7">
                <div class="text-[13px] font-bold uppercase tracking-wider text-text-secondary mb-3 flex items-center gap-1.5"><span>💵</span> Amount</div>
                <div class="bg-bg-secondary p-5 rounded-2xl border border-border">
                    <div class="relative flex items-center">
                        <span class="font-extrabold text-primary text-2xl mr-2">Rp</span>
                        <input type="number" id="amount" name="amount" placeholder="0" required
                            class="bg-transparent border-none text-[32px] font-extrabold text-text-primary p-0 h-auto w-full focus:outline-none focus:ring-0">
                    </div>
                </div>
            </div>

            <!-- 4. Source Type -->
            <div class="mb-7">
                <div class="text-[13px] font-bold uppercase tracking-wider text-text-secondary mb-3 flex items-center gap-1.5"><span>🔀</span> Source Type</div>
                <div class="source-type-toggle">
                    <label>
                        <input type="radio" name="sourceType" value="single" checked id="sourceTypeSingle">
                        <div class="source-type-option">
                            <span>👛</span> Single Pocket
                        </div>
                    </label>
                    <label>
                        <input type="radio" name="sourceType" value="multi" id="sourceTypeMulti">
                        <div class="source-type-option">
                            <span>🔀</span> Multi Pocket
                        </div>
                    </label>
                </div>
            </div>

            <!-- 5a. Pocket (Single Mode) -->
            <div class="mb-7" id="singlePocketSection">
                <div class="text-[13px] font-bold uppercase tracking-wider text-text-secondary mb-3 flex items-center gap-1.5"><span>👛</span> Pocket Source</div>
                <div class="option-grid">
                    {{!-- prettier-ignore --}}
                    {{#each (split "Kwintals,Groceries,Weekday Transport,Weekend
                    Transport,Investasi,Bandung,Sedeqah,IPL")}}
                    <label>
                        <input type="radio" name="pocket" value="{{this}}" class="option-input">
                        <div class="icon-btn">
                            <span class="text-[28px] mb-1.5">{{getPocketEmoji this}}</span>
                            <span class="text-[11px] font-semibold text-center text-text-secondary">{{this}}</span>
                        </div>
                    </label>
                    {{/each}}
                </div>
            </div>

            <!-- 5b. Pocket (Multi Mode) -->
            <div class="mb-7" id="multiPocketSection" style="display:none;">
                <div class="text-[13px] font-bold uppercase tracking-wider text-text-secondary mb-3 flex items-center gap-1.5"><span>🔀</span> Pocket Breakdown</div>
                <div class="breakdown-container" id="breakdownRows">
                    <!-- Dynamic rows inserted by JS -->
                </div>
                <button type="button" class="add-pocket-btn mt-3" id="addPocketBtn" onclick="addBreakdownRow()">
                    <span>➕</span> Add Pocket
                </button>

                <!-- Running Total -->
                <div class="breakdown-total mt-4" id="breakdownTotalCard">
                    <div class="breakdown-total-row mb-2">
                        <span class="label">Allocated</span>
                        <span class="value" id="allocatedTotal">Rp 0</span>
                    </div>
                    <div class="breakdown-total-row mb-2">
                        <span class="label">Transaction Amount</span>
                        <span class="value" id="transactionAmountDisplay">Rp 0</span>
                    </div>
                    <div class="breakdown-total-row">
                        <span class="label">Difference</span>
                        <span class="value" id="differenceDisplay">Rp 0</span>
                    </div>
                    <div class="breakdown-progress">
                        <div class="breakdown-progress-fill" id="breakdownProgressFill" style="width: 0%"></div>
                    </div>
                </div>
            </div>

            <!-- 5. Budget Month -->
            <div class="mb-7">
                <div class="text-[13px] font-bold uppercase tracking-wider text-text-secondary mb-3 flex items-center gap-1.5"><span>🗓️</span> Budget Month</div>
                <select id="budgetMonth" name="budgetMonth" class="input-dark appearance-none cursor-pointer font-semibold" required
                    style="background-image: url(&quot;data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2394A3B8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e&quot;); background-repeat: no-repeat; background-position: right 16px center; background-size: 16px; padding-right: 40px;">
                </select>
            </div>

            <!-- 6. Date Time -->
            <div class="mb-7">
                <div class="text-[13px] font-bold uppercase tracking-wider text-text-secondary mb-3 flex items-center gap-1.5"><span>📅</span> Date & Time</div>
                <input type="datetime-local" id="date" name="date" required class="input-dark">
            </div>

            <!-- Save directly under date/time -->
            <div class="mb-7">
                <button type="submit" class="transaction-save-btn" id="submitBtn">
                    Save Transaction
                </button>
            </div>
        </form>
    </div>

    <!-- Success Modal -->
    <div id="successModal" class="modal-overlay">
        <div class="modal-card text-center">
            <div class="text-5xl mb-4" id="successEmoji">🎉</div>
            <h3 class="text-xl font-bold text-text-primary mb-2">Transaction Saved!</h3>
            <p class="text-sm text-text-secondary mb-6" id="successMessage">Great job tracking your expenses!</p>
            <div class="flex flex-col gap-3">
                <button class="btn-neon w-full h-12" onclick="addAnother()">➕ Add Another Transaction</button>
                <button class="btn-ghost w-full h-12" onclick="window.location.href='/transactions'">🏠 Go to Transactions</button>
            </div>
        </div>
    </div>

    <div id="message" class="toast"></div>
    <script src="/js/common.js"></script>
    <script src="/js/confetti.js"></script>
    <script src="/js/transaction.js"></script>
</body>

</html>
