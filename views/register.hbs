<!DOCTYPE html>
<html lang="en">

<head>
    {{> head}}
    <title>Money Journal - Register</title>
</head>

<body class="flex flex-col justify-center items-center min-h-screen p-4 sm:p-8" style="background: radial-gradient(circle at top right, #efe6d5 0%, transparent 46%), var(--journal-bg);">

    <div class="w-full max-w-[400px] animate-fade-in relative pt-12 sm:pt-0">
        <!-- Back Button Mobile Only (absolute on mobile) -->
        <a href="/login" class="absolute top-0 left-0 w-10 h-10 rounded-full flex items-center justify-center cursor-pointer no-underline hover:opacity-80 transition-all sm:-left-3 sm:-top-3" style="background: var(--journal-panel); border: 1px solid var(--journal-line); color: var(--journal-soft-ink);" aria-label="Go back">
            <span class="material-symbols-outlined" style="font-size:20px;">arrow_back_ios_new</span>
        </a>

        <!-- Header -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-6 transition-transform hover:scale-105" style="background: var(--journal-panel); border: 1px solid var(--journal-line); box-shadow: 0 8px 20px rgba(23, 33, 58, 0.06);">
                <img src="/images/logo.png" alt="Money Journal Logo" class="w-10 h-10 object-contain rounded-xl">
            </div>
            <h1 class="page-title-ledger mb-2 text-center text-[28px]" style="color: var(--journal-ink); font-weight: 800;">Let's Start</h1>
            <p class="journal-metric-label" style="font-size: 12px;">CREATE AN ACCOUNT</p>
        </div>

        <!-- Form Card -->
        <div class="journal-surface p-6 sm:p-8">
            <h2 class="text-xl font-bold mb-6" style="color: var(--journal-ink);">Sign Up</h2>

            {{#if error}}
            <div class="p-3 rounded-xl text-sm mb-5 font-medium" style="background: rgba(237, 63, 39, 0.12); color: var(--journal-danger); border: 1px solid rgba(237, 63, 39, 0.2);">{{error}}</div>
            {{/if}}

            <form method="POST" action="/auth/register">
                <div class="mb-5">
                    <label for="username" class="transaction-field-label">Username</label>
                    <div class="relative">
                        <input type="text" id="username" name="username" placeholder="your_username" required
                            autocomplete="username" class="transaction-note-input !py-3.5 !rounded-2xl">
                    </div>
                </div>

                <div class="mb-5">
                    <label for="email" class="transaction-field-label">Email Address</label>
                    <div class="relative">
                        <input type="email" id="email" name="email" placeholder="you@email.com" required
                            autocomplete="email" class="transaction-note-input !py-3.5 !rounded-2xl">
                    </div>
                </div>

                <div class="mb-6">
                    <label for="password" class="transaction-field-label">Password</label>
                    <div class="relative">
                        <input type="password" id="password" name="password" placeholder="••••••••" required
                            autocomplete="new-password" class="transaction-note-input !py-3.5 !rounded-2xl">
                        <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 bg-transparent border-none cursor-pointer flex items-center transition-colors" style="color: var(--journal-soft-ink);" onclick="togglePw('password', this)"
                            aria-label="Toggle password">
                            <span class="material-symbols-outlined" style="font-size:20px;">visibility_off</span>
                        </button>
                    </div>
                </div>

                <button type="submit" class="transaction-save-btn mt-2">Create Account</button>
            </form>

            <div class="text-center mt-6 text-[14px]" style="color: var(--journal-soft-ink);">
                Already have an account? <a href="/login" class="font-bold no-underline transition-colors hover:opacity-80" style="color: var(--journal-accent);">Sign In</a>
            </div>
        </div>
    </div>

    <script>
        function togglePw(id, btn) {
            const input = document.getElementById(id);
            const icon = btn.querySelector('span');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        }
    </script>
</body>

</html>